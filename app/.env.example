# Privy app id — create an app at https://dashboard.privy.io and paste its App ID.
# Enable Email + Solana embedded wallets in the Privy dashboard (ADR-0005).
NEXT_PUBLIC_PRIVY_APP_ID=cmrhfn4cy027y0cjvye0wqfce

# Supabase project (rented realtime for the Feed, ADR-0006). Create a free project at
# https://supabase.com. Realtime channels power the live layer; the optional feed_events
# table (SQL in DEMO.md) persists history — without it the Feed is ephemeral but works.
# Leave blank to run without the Feed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solana RPC the app talks to (devnet for the demo).
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# RPC for the Pool-list scan (getProgramAccounts) only. The public devnet endpoint
# rate-limits that method hard — cold loads eat ~9s of 429 backoff before the 5s cache
# warms. Point this at a free Helius/Triton devnet key to make the first load instant.
# SCAN_RPC_URL=https://devnet.helius-rpc.com/?api-key=...

# The deployed finalwhistle program id (matches declare_id! / the IDL).
NEXT_PUBLIC_PROGRAM_ID=3twLVgxWB3fF6EkHGoNzH4ax8sH82fz2KZjgjwg4y7fs

# The USDC-like SPL mint the Pools use on devnet. Create one with
# `spl-token create-token --decimals 6` and fund test wallets; paste it here.
NEXT_PUBLIC_USDC_MINT=

# The Group every demo Pool belongs to (any pubkey; friend-Group id). Defaults to
# the program id if unset — fine for a single-group demo.
NEXT_PUBLIC_GROUP=

# --- Server-verified social backend (server-side only, no NEXT_PUBLIC) ---
# Privy app secret (dashboard -> App settings -> API keys). Verifies callers' access
# tokens in the /api/me and /api/groups/* routes.
PRIVY_APP_SECRET=
# Supabase service-role key (dashboard -> Settings -> API keys). Writes users/groups/
# group_members; anon clients are read-only on those tables.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: the /api/faucet minter key — must be the USDC mint authority and hold
# some SOL. The deploy wallet is both. Path to a keypair JSON file.
FAUCET_KEYPAIR=

# Demo knob: shift all fixture kickoffs by this many seconds (optional).
NEXT_PUBLIC_KICKOFF_OFFSET_SECONDS=
# txline_mock program override (optional; defaults to the deployed devnet mock).
NEXT_PUBLIC_TXLINE_PROGRAM_ID=

# --- Real TxLINE World Cup feed (optional; server-side only, no NEXT_PUBLIC) ---
# Activated API token from the one-time subscribe/activate flow (see keeper/txline-live.ts).
# Leave unset to run on the scripted stand-in data.
TXLINE_API_TOKEN=
# Optional: reuse a guest JWT / point at mainnet. Defaults: fresh guest JWT, devnet origin.
TXLINE_JWT=
TXLINE_ORIGIN=
