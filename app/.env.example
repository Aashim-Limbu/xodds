# Privy app id — create an app at https://dashboard.privy.io and paste its App ID.
# Enable Email + Solana embedded wallets in the Privy dashboard (ADR-0005).
NEXT_PUBLIC_PRIVY_APP_ID=

# Solana RPC the app talks to (devnet for the demo).
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# The deployed finalwhistle program id (matches declare_id! / the IDL).
NEXT_PUBLIC_PROGRAM_ID=3twLVgxWB3fF6EkHGoNzH4ax8sH82fz2KZjgjwg4y7fs

# The USDC-like SPL mint the Pools use on devnet. Create one with
# `spl-token create-token --decimals 6` and fund test wallets; paste it here.
NEXT_PUBLIC_USDC_MINT=

# The Group every demo Pool belongs to (any pubkey; friend-Group id). Defaults to
# the program id if unset — fine for a single-group demo.
NEXT_PUBLIC_GROUP=
