        {
          "name": "pool",
          "relations": [
            "entry"
          ]
        },
        {
          "name": "entry",
          "docs": [
            "The caller's Entry on the winning Outcome. Closed on a successful claim (rent to",
            "the User), which also prevents a second claim. Bound to this Pool and this User."
          ],
          "writable": true
        },
        {
          "name": "escrow",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
